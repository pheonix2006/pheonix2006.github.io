---
/**
 * 博客文章布局 - 使用温暖文艺配色
 * 为博客文章提供统一的布局样式
 */
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`${title} - ${SITE_TITLE}`} description={description} />
  </head>
  <body class="bg-warm-white min-h-screen">
    <!-- 导航栏 -->
    <Nav />

    <!-- 主内容区 -->
    <main class="max-w-3xl mx-auto px-6 py-12">
      <!-- 返回链接 -->
      <nav class="mb-8">
        <a
          href="/blog"
          class="inline-flex items-center text-warm-orange hover:text-warm-brown transition-colors font-serif"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          返回博客列表
        </a>
      </nav>

      <article class="blog-post">
        <!-- 文章头部 -->
        <header class="mb-8">
          <!-- 文章图片 -->
          {heroImage && typeof heroImage === 'object' && 'src' in heroImage ? (
            <div class="aspect-video rounded-lg overflow-hidden shadow-lg mb-6">
              <Image
                src={heroImage}
                alt={title}
                class="w-full h-full object-cover"
              />
            </div>
          ) : (
            <div class="aspect-video rounded-lg bg-gradient-to-br from-warm-orange/20 to-warm-brown/20 flex items-center justify-center mb-6">
              <span class="text-warm-orange text-6xl opacity-60">📝</span>
            </div>
          )}

          <!-- 标题和日期 -->
          <h1 class="text-4xl font-serif text-warm-brown mb-4">{title}</h1>

          <div class="flex flex-wrap items-center gap-4 text-warm-gray text-sm mb-4">
            <time>
              发布于 <FormattedDate date={pubDate} />
            </time>
            {updatedDate && (
              <time class="italic">
                更新于 <FormattedDate date={updatedDate} />
              </time>
            )}
          </div>

          <!-- 描述 -->
          <p class="text-lg text-warm-gray leading-relaxed">{description}</p>
        </header>

        <!-- 文章分隔线 -->
        <hr class="border-warm-beige mb-8" />

        <!-- 文章内容 -->
        <div class="blog-content text-warm-gray leading-relaxed">
          <slot />
        </div>
      </article>

      <!-- 底部返回链接 -->
      <nav class="mt-12 pt-8 border-t border-warm-beige">
        <a
          href="/blog"
          class="inline-flex items-center text-warm-orange hover:text-warm-brown transition-colors font-serif"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          返回博客列表
        </a>
      </nav>
    </main>

    <!-- 页脚 -->
    <Footer />
  </body>
</html>

<style>
  /* 博客内容样式 */
  .blog-content :global(h2) {
    font-size: 1.5rem;
    font-family: "Noto Serif SC", serif;
    color: #6b4423;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .blog-content :global(h3) {
    font-size: 1.25rem;
    font-family: "Noto Serif SC", serif;
    color: #6b4423;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .blog-content :global(h4) {
    font-size: 1.125rem;
    font-family: "Noto Serif SC", serif;
    color: #6b4423;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .blog-content :global(p) {
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .blog-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .blog-content :global(code) {
    background-color: #f4e8d9;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    color: #6b4423;
  }

  .blog-content :global(pre) {
    background-color: #6b4423;
    color: #f4e8d9;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .blog-content :global(pre code) {
    background-color: transparent;
    padding: 0;
    color: inherit;
  }

  .blog-content :global(blockquote) {
    border-left: 4px solid #e07a5f;
    padding-left: 1rem;
    font-style: italic;
    color: #5c5c5c;
    margin: 1.5rem 0;
  }

  .blog-content :global(a) {
    color: #e07a5f;
    transition: color 0.3s;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-content :global(a:hover) {
    color: #6b4423;
  }

  .blog-content :global(hr) {
    border: none;
    border-top: 1px solid #e8dcc8;
    margin: 2rem 0;
  }

  .blog-content :global(img) {
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }

  .blog-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
  }

  .blog-content :global(th),
  .blog-content :global(td) {
    border: 1px solid #e8dcc8;
    padding: 0.75rem;
    text-align: left;
  }

  .blog-content :global(th) {
    background-color: #f4e8d9;
    font-family: "Noto Serif SC", serif;
    color: #6b4423;
  }
</style>
