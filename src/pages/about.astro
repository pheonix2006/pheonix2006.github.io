// Mock 数据 - 联系方式
const contactInfo = [
  {
    type: 'Email',
    value: 'hello@example.com',
    link: 'mailto:hello@example.com',
    icon: 'email',
  },
  {
    type: 'GitHub',
    value: 'github.com/phoenix2006',
    link: 'https://github.com',
    icon: 'github',
