      { name: 'HTML/CSS', level: 95 },
      { name: 'JavaScript/TypeScript', level: 90 },
      { name: 'Vue.js', level: 85 },
      { name: 'React', level: 80 },
      { name: 'Astro', level: 75 },
    ],
  },
  {
    category: '后端开发',
    items: [
      { name: 'Node.js', level: 85 },
      { name: 'Python', level: 80 },
      { name: 'Java', level: 70 },
      { name: 'Go', level: 60 },
    ],
  },
  {
    category: '其他技能',
    items: [
      { name: 'Git', level: 90 },
      { name: 'Docker', level: 75 },
      { name: 'Linux', level: 80 },
      { name: 'SQL', level: 85 },
