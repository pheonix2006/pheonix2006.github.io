---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`关于我 - ${SITE_TITLE}`} description="了解更多关于 Phoenix 的信息，包括个人简介、技能和联系方式" />
  </head>
  <body class="bg-warm-white min-h-screen">
    <!-- 导航栏 -->
    <Nav />

    <!-- 主内容区 -->
    <main class="max-w-4xl mx-auto px-6 py-12">
      <!-- 页面标题 -->
      <header class="text-center mb-12">
        <h1 class="text-4xl font-serif text-warm-brown mb-4">关于我</h1>
        <div class="w-16 h-1 bg-warm-orange mx-auto rounded-full"></div>
      </header>

      <!-- 简介区域 -->
      <section class="about-intro mb-16">
        <div class="flex flex-col md:flex-row items-center gap-8">
          <!-- 头像 -->
          <div class="flex-shrink-0">
            <img
              src={aboutData.avatar}
              alt={aboutData.name}
              class="w-40 h-40 rounded-full object-cover border-4 border-warm-beige shadow-lg"
            />
          </div>

          <!-- 个人信息 -->
          <div class="flex-1 text-center md:text-left">
            <h2 class="text-3xl font-serif text-warm-brown mb-2">{aboutData.name}</h2>
            <p class="text-warm-orange text-lg mb-4">{aboutData.title}</p>

            <!-- 统计数据 -->
            <div class="flex justify-center md:justify-start gap-8 mb-6">
              <div class="text-center">
                <div class="text-2xl font-bold text-warm-brown">{aboutData.experience}</div>
                <div class="text-sm text-warm-gray">经验</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold text-warm-brown">{aboutData.projects}</div>
                <div class="text-sm text-warm-gray">项目</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold text-warm-brown">{aboutData.articles}</div>
                <div class="text-sm text-warm-gray">文章</div>
              </div>
            </div>
          </div>
        </div>

        <!-- 个人介绍 -->
        <div class="mt-8 space-y-4 text-warm-gray leading-relaxed">
          {aboutData.bio.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </section>

      <!-- 分隔线 -->
      <hr class="border-warm-beige mb-16" />

      <!-- 技能区域 -->
      <section class="skills-section mb-16">
        <h2 class="text-2xl font-serif text-warm-brown mb-8 text-center">技能专长</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {skills.map((skillGroup) => (
            <div class="skill-category bg-warm-beige/30 rounded-lg p-6">
              <h3 class="text-xl font-serif text-warm-brown mb-4 pb-2 border-b border-warm-orange/30">
                {skillGroup.category}
              </h3>
              <ul class="space-y-3">
                {skillGroup.items.map((skill) => (
                  <li>
                    <div class="flex justify-between mb-1">
                      <span class="text-warm-gray">{skill.name}</span>
                      <span class="text-warm-orange text-sm">{skill.level}%</span>
                    </div>
                    <div class="w-full bg-warm-beige rounded-full h-2">
                      <div
                        class="bg-warm-orange h-2 rounded-full transition-all duration-500"
                        style={`width: ${skill.level}%`}
                      ></div>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- 分隔线 -->
      <hr class="border-warm-beige mb-16" />

      <!-- 联系方式区域 -->
      <section class="contact-section">
        <h2 class="text-2xl font-serif text-warm-brown mb-8 text-center">联系方式</h2>

        <div class="bg-warm-beige/30 rounded-lg p-8">
          <p class="text-center text-warm-gray mb-8">
            欢迎通过以下方式与我取得联系，期待与你的交流！
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {contactInfo.map((contact) => (
              <a
                href={contact.link}
                target="_blank"
                rel="noopener noreferrer"
                class="contact-card flex flex-col items-center p-6 bg-warm-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 group"
              >
                <div class="w-12 h-12 flex items-center justify-center rounded-full bg-warm-orange/10 text-warm-orange mb-4 group-hover:bg-warm-orange group-hover:text-warm-white transition-colors duration-300">
                  <svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
                    <path fill="currentColor" d={icons[contact.icon]}></path>
                  </svg>
                </div>
                <div class="text-sm text-warm-gray mb-1">{contact.type}</div>
                <div class="text-warm-brown font-medium">{contact.value}</div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- 底部引导 -->
      <section class="mt-16 text-center">
        <p class="text-warm-gray mb-6">想了解更多？</p>
        <div class="flex justify-center gap-4">
          <a
            href="/projects"
            class="inline-block bg-warm-orange text-warm-white px-6 py-2 rounded-lg font-serif hover:bg-warm-brown transition-colors duration-300"
          >
            查看项目
          </a>
          <a
            href="/blog"
            class="inline-block bg-warm-beige text-warm-brown px-6 py-2 rounded-lg font-serif hover:bg-warm-orange hover:text-warm-white transition-colors duration-300"
          >
            阅读博客
          </a>
        </div>
      </section>
    </main>

    <!-- 页脚 -->
    <Footer />
  </body>
</html>
