---
/**
 * 博客列表页 - 展示所有博客文章
 * 使用温暖文艺配色，从 content collections 获取数据
 */
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Nav from '../../components/Nav.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

// 获取所有博客文章
let posts = [];
try {
  const allPosts = await getCollection('blog');
  posts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
} catch (e) {
  // 如果获取失败，使用 Mock 数据
  posts = [
    {
      id: 'first-post',
      data: {
        title: '第一篇博客文章',
        description: '欢迎来到我的博客，这是第一篇文章。探索技术、生活与创意。',
        pubDate: new Date('2026-03-08'),
        heroImage: undefined,
      },
    },
    {
      id: 'second-post',
      data: {
        title: '探索现代前端开发',
        description: '了解 Astro、React、Vue 等现代前端框架的特点和应用场景。',
        pubDate: new Date('2026-02-22'),
        heroImage: undefined,
      },
    },
    {
      id: 'third-post',
      data: {
        title: '设计系统的力量',
        description: '如何构建可扩展、一致的设计系统来提升团队效率。',
        pubDate: new Date('2026-02-15'),
        heroImage: undefined,
      },
    },
    {
      id: 'fourth-post',
      data: {
        title: '从零开始学习 TypeScript',
        description: 'TypeScript 入门指南，从基础类型到高级特性。',
        pubDate: new Date('2026-01-28'),
        heroImage: undefined,
      },
    },
    {
      id: 'fifth-post',
      data: {
        title: '响应式设计最佳实践',
        description: '构建适配所有设备的响应式网站的技术要点。',
        pubDate: new Date('2026-01-10'),
        heroImage: undefined,
      },
    },
    {
      id: 'sixth-post',
      data: {
        title: 'CSS Grid 完全指南',
        description: '掌握 CSS Grid 布局，创建复杂的网页布局。',
        pubDate: new Date('2025-12-20'),
        heroImage: undefined,
      },
    },
  ];
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`博客 - ${SITE_TITLE}`} description="阅读我的技术博客和思考" />
  </head>
  <body class="bg-warm-white min-h-screen">
    <!-- 导航栏 -->
    <Nav />

    <!-- 主内容区 -->
    <main class="max-w-4xl mx-auto px-6 py-12">
      <!-- 页面标题 -->
      <header class="text-center mb-12">
        <h1 class="text-4xl font-serif text-warm-brown mb-4">博客文章</h1>
        <p class="text-warm-gray text-lg">记录技术探索与生活感悟</p>
      </header>

      <!-- 文章列表 -->
      <section class="blog-list space-y-8">
        {posts.map((post, index) => (
          <article class="blog-card bg-warm-beige rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <a href={`/blog/${post.id}/`} class="block md:flex">
              <!-- 文章图片 -->
              <div class={`md:w-1/3 ${index === 0 ? 'md:w-full' : ''}`}>
                <div class={`aspect-video md:aspect-[4/3] bg-gradient-to-br from-warm-orange/20 to-warm-brown/20 flex items-center justify-center overflow-hidden ${index === 0 ? 'md:aspect-[21/9]' : ''}`}>
                  {post.data.heroImage && typeof post.data.heroImage === 'object' && 'src' in post.data.heroImage ? (
                    <Image
                      src={post.data.heroImage}
                      alt={post.data.title}
                      class="w-full h-full object-cover"
                    />
                  ) : (
                    <span class="text-warm-orange text-5xl opacity-60">📝</span>
                  )}
                </div>
              </div>

              <!-- 文章信息 -->
              <div class={`p-5 ${index === 0 ? 'md:w-full' : 'md:w-2/3 md:flex md:flex-col md:justify-center'}`}>
                <time class="text-xs text-warm-gray/70 block mb-2">
                  <FormattedDate date={post.data.pubDate} />
                </time>

                <h2 class={`font-serif text-warm-brown mb-2 ${index === 0 ? 'text-2xl' : 'text-xl'}`}>
                  <span class="hover:text-warm-orange transition-colors">
                    {post.data.title}
                  </span>
                </h2>

                <p class="text-sm text-warm-gray line-clamp-2">
                  {post.data.description}
                </p>

                <span class="inline-block mt-3 text-sm text-warm-orange hover:text-warm-brown transition-colors">
                  阅读全文 →
                </span>
              </div>
            </a>
          </article>
        ))}
      </section>

      <!-- 空状态 -->
      {posts.length === 0 && (
        <div class="text-center py-16">
          <p class="text-warm-gray text-lg">暂无文章</p>
        </div>
      )}
    </main>

    <!-- 页脚 -->
    <Footer />
  </body>
</html>
